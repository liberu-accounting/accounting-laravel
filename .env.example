APP_NAME="Liberu Accounting"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

MULTITENANCY=false

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=liberu_accounting
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
# Set BROADCAST_DRIVER=reverb once REVERB_APP_KEY/SECRET are configured
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Laravel Reverb (WebSockets)
REVERB_APP_ID=accounting
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SCALING_ENABLED=false

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Laravel Horizon
HORIZON_PATH=horizon
HORIZON_PREFIX=

# Socialstream OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/oauth/github/callback"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/oauth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/oauth/facebook/callback"

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI="${APP_URL}/oauth/gitlab/callback"

BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_REDIRECT_URI="${APP_URL}/oauth/bitbucket/callback"

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/oauth/linkedin/callback"

LINKEDIN_OPENID_CLIENT_ID=
LINKEDIN_OPENID_CLIENT_SECRET=
LINKEDIN_OPENID_REDIRECT_URI="${APP_URL}/oauth/linkedin-open-id/callback"

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI="${APP_URL}/oauth/slack/callback"

TWITTER_OAUTH2_CLIENT_ID=
TWITTER_OAUTH2_CLIENT_SECRET=
TWITTER_OAUTH2_REDIRECT_URI="${APP_URL}/oauth/twitter-oauth-2/callback"

# Plaid API Configuration
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=
PLAID_WEBHOOK_VERIFICATION_KEY=
PLAID_OAUTH_REDIRECT_URI=

# Revolut Business API Configuration
REVOLUT_CLIENT_ID=
REVOLUT_CLIENT_SECRET=
REVOLUT_ENV=sandbox
REVOLUT_REDIRECT_URI=
REVOLUT_WEBHOOK_SECRET=

# Wise API Configuration
WISE_CLIENT_ID=
WISE_CLIENT_SECRET=
WISE_ENV=sandbox
WISE_REDIRECT_URI=
WISE_WEBHOOK_PUBLIC_KEY=

# HMRC API Configuration
HMRC_ENABLED=false
HMRC_ENVIRONMENT=sandbox
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
HMRC_SERVER_TOKEN=
HMRC_CALLBACK_URL=
HMRC_VAT_ENABLED=false
HMRC_PAYE_ENABLED=false
HMRC_RTI_ENABLED=false
HMRC_CT_ENABLED=false
HMRC_LOGGING_ENABLED=true
HMRC_LOG_CHANNEL=stack
HMRC_TIMEOUT=30

